# Copie este arquivo para .env e preencha as chaves.
# Você só precisa preencher a do provider que vai usar.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Provider padrão: "openai" ou "gemini"
LLM_PROVIDER=gemini

# Tavily Search — https://tavily.com (free tier ~1000 buscas/mês)
# Usado pelos notebooks M1A4 (agente de pesquisa) e M1A7 (planejador de viagens).
TAVILY_API_KEY=

# ───────────────────────── Desafio final da trilha ─────────────────────────
# Etapa 1 — n8n "Weather & Packing Checklist" (webhook).
# URL de PRODUÇÃO do webhook depois de importar o workflow e ativá-lo.
# Em dev (workflow aberto + botão "Test workflow") troque /webhook/ por /webhook-test/.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/weather-packing

# Etapa 2 — servidor MCP "POI Finder".
# OPCIONAL: se vazio, o servidor usa Overpass/OpenStreetMap (sem chave).
# Se preenchido, usa OpenTripMap. Cadastro: https://dev.opentripmap.org
OPENTRIPMAP_API_KEY=

# Copie este arquivo para .env e preencha as chaves.
# Você só precisa preencher a do provider que vai usar.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Provider padrão: "openai" ou "gemini"
LLM_PROVIDER=gemini

# Tavily Search — https://tavily.com (free tier ~1000 buscas/mês)
# Usado pelo notebook M1A4 (agente de pesquisa com LangGraph).
TAVILY_API_KEY=
